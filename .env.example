# ===== LLM provider API keys =====
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get from https://platform.openai.com/
OPENAI_API_KEY=

# Get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Get from https://bailian.console.aliyun.com/  (for Qwen)
DASHSCOPE_API_KEY=

# Optional fallback router: https://openrouter.ai/
OPENROUTER_API_KEY=

# ===== Defaults =====
# Pick one of: claude | openai | deepseek | qwen
DEFAULT_PROVIDER=claude
DEFAULT_MODEL_CLAUDE=claude-sonnet-4-5
DEFAULT_MODEL_OPENAI=gpt-4o
DEFAULT_MODEL_DEEPSEEK=deepseek-chat
DEFAULT_MODEL_QWEN=qwen-max

# ===== Project settings =====
LOG_LEVEL=INFO
TRAJECTORY_DIR=./trajectories
