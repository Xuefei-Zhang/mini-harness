# ===== LLM provider API keys =====
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get from https://platform.openai.com/
OPENAI_API_KEY=

# Get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Get from https://bailian.console.aliyun.com/  (for Qwen)
DASHSCOPE_API_KEY=

# Optional fallback router: https://openrouter.ai/
OPENROUTER_API_KEY=

# ===== Local vLLM provider (主力) =====
# vLLM serves on OpenAI-compatible endpoint, default http://localhost:8000/v1
# Start: vllm serve Qwen/Qwen3-27B-FP8 --tensor-parallel-size 1
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY  # no key needed for local, just a placeholder

# ===== Defaults =====
# Pick one of: vllm | claude | openai | deepseek | qwen
DEFAULT_PROVIDER=vllm
DEFAULT_MODEL_VLLM=Qwen3-27B-FP8
DEFAULT_MODEL_CLAUDE=claude-sonnet-4-5
DEFAULT_MODEL_OPENAI=gpt-4o
DEFAULT_MODEL_DEEPSEEK=deepseek-chat
DEFAULT_MODEL_QWEN=qwen-max

# ===== Project settings =====
LOG_LEVEL=INFO
TRAJECTORY_DIR=./trajectories
